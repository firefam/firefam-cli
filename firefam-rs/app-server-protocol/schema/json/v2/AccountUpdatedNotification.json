{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AuthMode": {
      "description": "Authentication mode for FirefamAI-backed providers.",
      "oneOf": [
        {
          "description": "FirefamAI API key provided by the caller and stored by Firefam.",
          "enum": [
            "apikey"
          ],
          "type": "string"
        },
        {
          "description": "ChatGPT OAuth managed by Firefam (tokens persisted and refreshed by Firefam).",
          "enum": [
            "chatgpt"
          ],
          "type": "string"
        },
        {
          "description": "[UNSTABLE] FOR FIREFAMAI INTERNAL USE ONLY - DO NOT USE.\n\nChatGPT auth tokens are supplied by an external host app and are only stored in memory. Token refresh must be handled by the external host app.",
          "enum": [
            "chatgptAuthTokens"
          ],
          "type": "string"
        },
        {
          "description": "Programmatic Firefam auth backed by a registered Agent Identity.",
          "enum": [
            "agentIdentity"
          ],
          "type": "string"
        }
      ]
    },
    "PlanType": {
      "enum": [
        "free",
        "go",
        "plus",
        "pro",
        "prolite",
        "team",
        "self_serve_business_usage_based",
        "business",
        "enterprise_cbp_usage_based",
        "enterprise",
        "edu",
        "unknown"
      ],
      "type": "string"
    }
  },
  "properties": {
    "authMode": {
      "anyOf": [
        {
          "$ref": "#/definitions/AuthMode"
        },
        {
          "type": "null"
        }
      ]
    },
    "planType": {
      "anyOf": [
        {
          "$ref": "#/definitions/PlanType"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "title": "AccountUpdatedNotification",
  "type": "object"
}